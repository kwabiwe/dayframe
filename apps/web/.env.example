DATABASE_URL=postgres://dayframe:dayframe@localhost:54322/dayframe
NEXT_PUBLIC_DAYFRAME_API_BASE=http://localhost:3000
# NEXT_PUBLIC_DAYFRAME_MAP_STYLE_URL=https://maps.example.com/styles/dayframe/style.json
DAYFRAME_AUTH_MODE=dev
DAYFRAME_DEV_USER_ID=00000000-0000-4000-8000-000000000001
DAYFRAME_DEV_WORKSPACE_ID=00000000-0000-4000-8000-000000000010
DAYFRAME_INGEST_TOKEN=
# Server-authoritative Location Intelligence mode. Keep shadow until hosted
# migration, RLS, TestFlight and physical-device validation are complete.
DAYFRAME_LOCATION_ROLLOUT_MODE=v2_shadow
# Required by Vercel Cron before the retention schedule can run.
CRON_SECRET=
