{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@dayframe/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@dayframe/shared/*": [
        "../../packages/shared/src/*"
      ]
    }
  },
  "include": [
    "app",
    "modules",
    "src",
    "expo-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
