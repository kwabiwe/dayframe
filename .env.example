DATABASE_URL=postgres://dayframe:dayframe@localhost:54322/dayframe
NEXT_PUBLIC_DAYFRAME_API_BASE=http://localhost:3000
EXPO_PUBLIC_DAYFRAME_API_BASE=http://localhost:3000
DAYFRAME_AUTH_MODE=dev
DAYFRAME_DEV_USER_ID=00000000-0000-4000-8000-000000000001
DAYFRAME_DEV_WORKSPACE_ID=00000000-0000-4000-8000-000000000010
# Production auth/hosting:
# DAYFRAME_AUTH_MODE=provider
# DATABASE_URL=postgres://postgres.[project-ref]:[password]@[pooler-host]:6543/postgres?sslmode=require
# NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# DAYFRAME_ALLOWED_SIGNUP_EMAILS=you@example.com,friend@example.com
# DAYFRAME_SIGNUPS_ENABLED=false
# Set a local-only secret when posting events from a bridge or native app outside dev session mode.
DAYFRAME_INGEST_TOKEN=
# Optional Toggl importer settings. Never commit real tokens.
TOGGL_API_TOKEN=
TOGGL_WORKSPACE_ID=
