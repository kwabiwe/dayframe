DATABASE_URL=postgres://dayframe:dayframe@localhost:54322/dayframe
# Local web and iOS development only:
NEXT_PUBLIC_DAYFRAME_API_BASE=http://localhost:3000
# Optional private/licensed MapLibre style for location evidence review. When
# omitted, Dayframe renders evidence on a tile-free local canvas.
# NEXT_PUBLIC_DAYFRAME_MAP_STYLE_URL=https://maps.example.com/styles/dayframe/style.json
EXPO_PUBLIC_DAYFRAME_API_BASE=http://localhost:3000
DAYFRAME_AUTH_MODE=dev
DAYFRAME_DEV_USER_ID=00000000-0000-4000-8000-000000000001
DAYFRAME_DEV_WORKSPACE_ID=00000000-0000-4000-8000-000000000010
# Production auth/hosting:
# DAYFRAME_AUTH_MODE=provider
# DATABASE_URL=postgres://postgres.[project-ref]:[password]@[pooler-host]:6543/postgres
# NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# NEXT_PUBLIC_SUPABASE_ANON_KEY= # Legacy fallback if your Supabase project still uses anon JWT keys.
# DAYFRAME_ALLOWED_SIGNUP_EMAILS=you@example.com,friend@example.com
# DAYFRAME_SIGNUPS_ENABLED=false
# Hosted iOS builds should point at Vercel, not Supabase:
# EXPO_PUBLIC_DAYFRAME_API_BASE=https://your-vercel-domain.vercel.app
# Set a local-only secret when posting events from a bridge or native app outside dev session mode.
DAYFRAME_INGEST_TOKEN=
# Server-authoritative Location Intelligence mode. Safe default: diagnostics
# only; V1 remains responsible for user-visible suggestions.
DAYFRAME_LOCATION_ROLLOUT_MODE=v2_shadow
# Required by Vercel Cron before the retention schedule can run.
CRON_SECRET=
